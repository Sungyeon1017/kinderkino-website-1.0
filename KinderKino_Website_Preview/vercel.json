{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/birthdays",
      "destination": "/birthdays.html"
    },
    {
      "source": "/membership",
      "destination": "/membership.html"
    },
    {
      "source": "/event",
      "destination": "/event.html"
    },
    {
      "source": "/inquiry",
      "destination": "/inquiry.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
